{
	servers {
		trusted_proxies static private_ranges
		client_ip_headers CF-Connecting-IP X-Forwarded-For
		trusted_proxies_strict
	}
}

{$HOMEPAGE_DOMAIN} {
	encode zstd gzip
	log

	header {
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
	}

	reverse_proxy homepage:3102
}

{$OBI_DOMAIN} {
	encode zstd gzip
	log

	header {
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		-Server
	}

	reverse_proxy obi:5984 {
		flush_interval -1
	}
}

{$DOMAIN} {
	encode zstd gzip
	log

	header {
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
	}

	redir /bot /bot/ 308
	redir /videos /videos/ 308

	handle_path /videos/* {
		root * /srv/videos
		file_server
	}

	handle_path /bot/* {
		reverse_proxy bot-core:3000
	}

	handle {
		reverse_proxy bot-core:3000
	}
}
