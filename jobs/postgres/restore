#!/usr/bin/env bash
set -euo pipefail

job_path="$(realpath "${BASH_SOURCE[0]}")"
source "$(dirname -- "$job_path")/../../scripts/lib/common.sh"

archive="${1:-}"
container_archive="/tmp/platform-restore.dump"

if [[ "${PLATFORM_RESTORE_CONFIRMED:-}" != "yes" ]]; then
  printf 'Set PLATFORM_RESTORE_CONFIRMED=yes to replace the target PostgreSQL database.\n' >&2
  exit 1
fi

if [[ ! -f "$archive" ]]; then
  printf 'Usage: PLATFORM_RESTORE_CONFIRMED=yes %s BACKUP.dump\n' "$0" >&2
  exit 1
fi

cleanup() {
  compose postgres exec -T postgres rm -f "$container_archive" >/dev/null 2>&1 || true
}
trap cleanup EXIT

compose postgres cp "$archive" "postgres:$container_archive"
compose postgres exec -T -u root postgres chmod 0644 "$container_archive"
compose postgres exec -T postgres pg_restore --list "$container_archive" >/dev/null
compose postgres exec -T postgres sh -ceu '
  pg_restore \
    --clean \
    --if-exists \
    --exit-on-error \
    --no-owner \
    --no-privileges \
    --username="$POSTGRES_USER" \
    --dbname="$POSTGRES_DB" \
    "$1"
' sh "$container_archive"

printf 'Restored PostgreSQL from %s\n' "$archive"
