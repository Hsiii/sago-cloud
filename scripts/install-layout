#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

install -d -m 0755 "$PLATFORM_ROOT"
install -d -m 0700 "$SECRETS_ROOT" "$BACKUPS_ROOT"
install -d -m 0755 "$STATE_ROOT"

ln -sfn "$OPERATIONS_ROOT/edge" "$PLATFORM_ROOT/edge"
ln -sfn "$OPERATIONS_ROOT/services" "$PLATFORM_ROOT/services"
ln -sfn "$OPERATIONS_ROOT/jobs" "$PLATFORM_ROOT/jobs"

ensure_docker_networks
ensure_docker_volumes
