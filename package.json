{
  "name": "platform-infra",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "bun scripts/deploy.mjs all",
    "deploy:all": "bun scripts/deploy.mjs all",
    "deploy:edge": "bun scripts/deploy.mjs edge",
    "deploy:bot-core": "bun scripts/deploy.mjs bot-core",
    "deploy:minisago": "bun scripts/deploy.mjs minisago",
    "deploy:minisago-worker": "bun scripts/deploy.mjs minisago-worker",
    "deploy:obi": "bun scripts/deploy.mjs obi",
    "deploy:homepage": "bun scripts/deploy.mjs homepage",
    "deploy:postgres": "bun scripts/deploy.mjs postgres",
    "backup:postgres": "ssh platform /srv/platform/jobs/postgres/backup",
    "restore:postgres": "ssh platform /srv/platform/jobs/postgres/restore",
    "verify:postgres-backup": "ssh platform /srv/platform/jobs/postgres/verify-backup",
    "install:postgres-backups": "ssh platform /srv/platform/operations/scripts/install-postgres-backup-timers",
    "install:health-watch": "ssh platform /srv/platform/operations/scripts/install-health-watch-timer",
    "install:ssh-hardening": "ssh platform /srv/platform/operations/scripts/install-ssh-hardening",
    "test": "bun run test:security && bash tests/deployment-boundary && bash tests/recipes-retired",
    "test:security": "bun run test:security:root && bun run test:security:network",
    "test:security:network": "bash tests/network-segmentation",
    "test:security:root": "bash tests/root-health-watch-boundary",
    "status": "ssh platform /srv/platform/operations/scripts/status"
  }
}
