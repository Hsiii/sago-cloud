#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

container_id="$("${DOCKER[@]}" compose -f "$COMPOSE_FILE" ps -q brawl-stars-claimer)"
container_running="$("${DOCKER[@]}" inspect -f '{{.State.Running}}' "$container_id" 2>/dev/null || true)"

if [ "$container_running" != "true" ]; then
  "$ORACLE_ROOT/scripts/deploy-brawlstars"
fi

"${DOCKER[@]}" compose -f "$COMPOSE_FILE" exec -T \
  brawl-stars-claimer \
  bun src/server.ts --claim-once "$@"
