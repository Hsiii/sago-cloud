tunnel: <tunnel-id>
credentials-file: /etc/cloudflared/credentials.json

ingress:
  - hostname: <homepage-hostname>
    service: https://edge:443
    originRequest:
      originServerName: <homepage-hostname>
  - hostname: <obi-hostname>
    service: https://edge:443
    originRequest:
      originServerName: <obi-hostname>
  - hostname: <bot-hostname>
    service: https://edge:443
    originRequest:
      originServerName: <bot-hostname>
  - service: http_status:404
