#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

mode="${1:---disable}"
case "$mode" in
  --enable | --disable) ;;
  *)
    printf 'Usage: %s [--enable|--disable]\n' "$0" >&2
    exit 64
    ;;
esac

if [ "$(id -u)" -eq 0 ]; then
  SUDO=()
else
  SUDO=(sudo -n)
fi

cron_marker="# oracle-brawlstars-claim"
legacy_cron_marker="# oracle-supercell-reward"
current_cron="$(mktemp)"
next_cron="$(mktemp)"

cleanup() {
  rm -f "$current_cron" "$next_cron"
}
trap cleanup EXIT

crontab -l > "$current_cron" 2>/dev/null || true
grep -vF "$cron_marker" "$current_cron" \
  | grep -vF "$legacy_cron_marker" > "$next_cron" || true
crontab "$next_cron"

"${SUDO[@]}" install -m 0644 \
  "$ORACLE_ROOT/systemd/oracle-brawlstars-claim.service" \
  /etc/systemd/system/oracle-brawlstars-claim.service
"${SUDO[@]}" install -m 0644 \
  "$ORACLE_ROOT/systemd/oracle-brawlstars-claim.timer" \
  /etc/systemd/system/oracle-brawlstars-claim.timer
"${SUDO[@]}" systemctl daemon-reload

if [ "$mode" = "--enable" ]; then
  "${SUDO[@]}" systemctl enable --now oracle-brawlstars-claim.timer
  printf 'Enabled Brawl Stars claim timer.\n'
else
  "${SUDO[@]}" systemctl disable --now oracle-brawlstars-claim.timer >/dev/null 2>&1 || true
  printf 'Installed Brawl Stars claim timer, left disabled until profile authentication is repaired.\n'
fi

"${SUDO[@]}" systemctl reset-failed oracle-brawlstars-claim.service >/dev/null 2>&1 || true
"${SUDO[@]}" systemctl status oracle-brawlstars-claim.timer --no-pager || true

