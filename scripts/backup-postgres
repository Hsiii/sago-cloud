#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

backup_dir="${POSTGRES_BACKUP_DIR:-"$ORACLE_ROOT/../backups/postgres"}"
retention_days="${POSTGRES_BACKUP_RETENTION_DAYS:-7}"

if ! [[ "$retention_days" =~ ^[1-9][0-9]*$ ]]; then
  printf 'POSTGRES_BACKUP_RETENTION_DAYS must be a positive integer.\n' >&2
  exit 64
fi

install -d -m 0700 "$backup_dir"

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
target="$backup_dir/oracle-$timestamp.dump"
temporary="$target.partial"

cleanup() {
  rm -f "$temporary"
}
trap cleanup EXIT

"${DOCKER[@]}" compose -f "$COMPOSE_FILE" exec -T postgres sh -ceu '
  pg_dump \
    --format=custom \
    --compress=6 \
    --no-owner \
    --no-privileges \
    --username="$POSTGRES_USER" \
    --dbname="$POSTGRES_DB"
' > "$temporary"

"${DOCKER[@]}" compose -f "$COMPOSE_FILE" exec -T postgres \
  pg_restore --list < "$temporary" >/dev/null

chmod 0600 "$temporary"
mv "$temporary" "$target"
find "$backup_dir" -maxdepth 1 -type f -name 'oracle-*.dump' \
  -mtime "+$retention_days" -delete

printf 'Created verified PostgreSQL backup: %s\n' "$target"

