#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
compose="$repo_root/services/cloudflared/compose.yaml"
edge_compose="$repo_root/edge/compose.yaml"
edge_caddyfile="$repo_root/edge/Caddyfile"
public_ingress_installer="$repo_root/scripts/install-public-ingress-timer"
public_ingress_service="$repo_root/systemd/sago-cloud-public-ingress.service"
public_ingress_timer="$repo_root/systemd/sago-cloud-public-ingress.timer"

grep -Fq 'cloudflare/cloudflared:2026.7.1' "$compose"
grep -Fq '/srv/sago-cloud/secrets/cloudflared:/etc/cloudflared:ro' "$compose"
grep -Fq 'name: ${EDGE_NETWORK_NAME:-sago_cloud_edge}' "$compose"
grep -Fq -- '--config /etc/cloudflared/config.yml run' "$compose"

if grep -Eq '(^|[[:space:]])ports:' "$compose"; then
  printf 'cloudflared must not publish host ports\n' >&2
  exit 1
fi

if grep -Eq '(^|[[:space:]])ports:' "$edge_compose"; then
  printf 'Caddy origin must not publish host ports after Tunnel cutover\n' >&2
  exit 1
fi

if grep -Eq 'tunnel: [^<]' "$repo_root/env/cloudflared.config.yml.example"; then
  printf 'cloudflared example contains a live tunnel identifier\n' >&2
  exit 1
fi

grep -Fq 'credentials-file: /etc/cloudflared/credentials.json' "$repo_root/env/cloudflared.config.yml.example"
grep -Fq 'service: https://edge:443' "$repo_root/env/cloudflared.config.yml.example"
grep -Fq 'originServerName:' "$repo_root/env/cloudflared.config.yml.example"
grep -Fq "stat -c '%u:%a'" "$repo_root/scripts/deploy-cloudflared"
grep -Fq '65532:600' "$repo_root/scripts/deploy-cloudflared"
grep -Fq 'trusted_proxies static private_ranges' "$edge_caddyfile"
grep -Fq 'client_ip_headers CF-Connecting-IP X-Forwarded-For' "$edge_caddyfile"
grep -Fq 'trusted_proxies_strict' "$edge_caddyfile"

if [[ "$(grep -c $'\tlog' "$edge_caddyfile")" -ne 4 ]]; then
  printf 'Every public Caddy site must emit access logs with parsed client IPs\n' >&2
  exit 1
fi

grep -Fq 'EnvironmentFile=/srv/sago-cloud/secrets/public-ingress.env' "$public_ingress_service"
grep -Fq 'DynamicUser=true' "$public_ingress_service"
if grep -Eq '^(User|Group)=' "$public_ingress_service"; then
  printf 'Public ingress verification must not share a persistent service account\n' >&2
  exit 1
fi
grep -Fq 'ExecStart=/usr/local/libexec/sago-cloud-public-ingress/current/scripts/verify-public-ingress' \
  "$public_ingress_service"
grep -Fq 'OnUnitActiveSec=5min' "$public_ingress_timer"
grep -Fq 'RandomizedDelaySec=30s' "$public_ingress_timer"
grep -Fq 'scripts/verify-public-ingress' "$public_ingress_installer"
grep -Fq 'HOMEPAGE_EXPECTED_STATUS:-200' "$repo_root/scripts/verify-public-ingress"
grep -Fq 'OBI_EXPECTED_STATUS:-401' "$repo_root/scripts/verify-public-ingress"
grep -Fq 'MEDIA_EXPECTED_STATUS:-404' "$repo_root/scripts/verify-public-ingress"

printf 'Cloudflare Tunnel service is public-safe and uses the private edge network\n'
