{$DOMAIN} {
	encode zstd gzip

	header {
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
	}

	redir /wm31 /wm31/ 308
	redir /morning /morning/ 308
	redir /recipe /recipe/ 308
	redir /videos /videos/ 308

	handle_path /videos/* {
		root * /srv/videos
		file_server
	}

	handle_path /recipe/* {
		reverse_proxy recipe-site:3101
	}

	handle /morning/* {
		reverse_proxy morning-dashboard:3100
	}

	handle_path /wm31/* {
		reverse_proxy wm31bot:3000
	}

	handle {
		reverse_proxy wm31bot:3000
	}
}
