#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
compose="$repo_root/services/cloudflared/compose.yaml"
edge_compose="$repo_root/edge/compose.yaml"

grep -Fq 'cloudflare/cloudflared:2026.7.1' "$compose"
grep -Fq '/srv/sago-cloud/secrets/cloudflared:/etc/cloudflared:ro' "$compose"
grep -Fq 'name: ${EDGE_NETWORK_NAME:-sago_cloud_edge}' "$compose"
grep -Fq -- '--config /etc/cloudflared/config.yml run' "$compose"

if grep -Eq '(^|[[:space:]])ports:' "$compose"; then
  printf 'cloudflared must not publish host ports\n' >&2
  exit 1
fi

if grep -Eq '(^|[[:space:]])ports:' "$edge_compose"; then
  printf 'Caddy origin must not publish host ports after Tunnel cutover\n' >&2
  exit 1
fi

if grep -Eq 'tunnel: [^<]' "$repo_root/env/cloudflared.config.yml.example"; then
  printf 'cloudflared example contains a live tunnel identifier\n' >&2
  exit 1
fi

grep -Fq 'credentials-file: /etc/cloudflared/credentials.json' "$repo_root/env/cloudflared.config.yml.example"
grep -Fq 'service: https://edge:443' "$repo_root/env/cloudflared.config.yml.example"
grep -Fq 'originServerName:' "$repo_root/env/cloudflared.config.yml.example"
grep -Fq "stat -c '%u:%a'" "$repo_root/scripts/deploy-cloudflared"
grep -Fq '65532:600' "$repo_root/scripts/deploy-cloudflared"

printf 'Cloudflare Tunnel service is public-safe and uses the private edge network\n'
