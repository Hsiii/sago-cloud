#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

mode="${1:---disable}"
case "$mode" in
  --enable | --disable) ;;
  *)
    printf 'Usage: %s [--enable|--disable]\n' "$0" >&2
    exit 64
    ;;
esac

if [ "$(id -u)" -eq 0 ]; then
  SUDO=()
else
  SUDO=(sudo -n)
fi

cron_marker="# platform-brawlstars-claim"
legacy_cron_markers=(
  "# oracle-brawlstars-claim"
  "# oracle-supercell-reward"
)
current_cron="$(mktemp)"
next_cron="$(mktemp)"

cleanup() {
  rm -f "$current_cron" "$next_cron"
}
trap cleanup EXIT

crontab -l > "$current_cron" 2>/dev/null || true
cp "$current_cron" "$next_cron"
for marker in "$cron_marker" "${legacy_cron_markers[@]}"; do
  grep -vF "$marker" "$next_cron" > "$current_cron" || true
  mv "$current_cron" "$next_cron"
done
crontab "$next_cron"

"${SUDO[@]}" install -m 0644 \
  "$INFRA_ROOT/systemd/platform-brawlstars-claim.service" \
  /etc/systemd/system/platform-brawlstars-claim.service
"${SUDO[@]}" install -m 0644 \
  "$INFRA_ROOT/systemd/platform-brawlstars-claim.timer" \
  /etc/systemd/system/platform-brawlstars-claim.timer
"${SUDO[@]}" systemctl daemon-reload

if [ "$mode" = "--enable" ]; then
  "${SUDO[@]}" systemctl enable --now platform-brawlstars-claim.timer
  printf 'Enabled Brawl Stars claim timer.\n'
else
  "${SUDO[@]}" systemctl disable --now platform-brawlstars-claim.timer >/dev/null 2>&1 || true
  printf 'Installed Brawl Stars claim timer, left disabled until profile authentication is repaired.\n'
fi

"${SUDO[@]}" systemctl reset-failed platform-brawlstars-claim.service >/dev/null 2>&1 || true
"${SUDO[@]}" systemctl status platform-brawlstars-claim.timer --no-pager || true
