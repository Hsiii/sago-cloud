#!/usr/bin/env bash
set -euo pipefail

job_path="$(realpath "${BASH_SOURCE[0]}")"
source "$(dirname -- "$job_path")/../../scripts/lib/common.sh"

backup_dir="${POSTGRES_BACKUP_DIR:-"$BACKUPS_ROOT/postgres"}"
verify_database="sago_cloud_backup_verify"
container_archive="/tmp/sago-cloud-backup-verify.dump"
latest_backup="$(find "$backup_dir" -maxdepth 1 -type f -name 'postgres-*.dump' -print \
  | sort | tail -n 1)"

if [ -z "$latest_backup" ]; then
  printf 'No PostgreSQL backup found in %s.\n' "$backup_dir" >&2
  exit 1
fi

cleanup() {
  compose postgres exec -T postgres sh -ceu '
    dropdb --if-exists --username="$POSTGRES_USER" "$1"
    rm -f "$2"
  ' sh "$verify_database" "$container_archive" >/dev/null 2>&1 || true
}
trap cleanup EXIT

compose postgres cp "$latest_backup" "postgres:$container_archive"
compose postgres exec -T -u root postgres chmod 0644 "$container_archive"
compose postgres exec -T postgres sh -ceu '
  dropdb --if-exists --username="$POSTGRES_USER" "$1"
  createdb --username="$POSTGRES_USER" "$1"
  pg_restore \
    --exit-on-error \
    --no-owner \
    --no-privileges \
    --username="$POSTGRES_USER" \
    --dbname="$1" \
    "$2"
  psql --username="$POSTGRES_USER" --dbname="$1" --tuples-only \
    --command="SELECT count(*) FROM pg_catalog.pg_class" >/dev/null
' sh "$verify_database" "$container_archive"

printf 'Restored and queried PostgreSQL backup successfully: %s\n' "$latest_backup"
