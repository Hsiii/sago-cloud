#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

if [ "$(id -u)" -eq 0 ]; then
  SUDO=()
else
  SUDO=(sudo -n)
fi

install -d -m 0755 "$STATE_ROOT/health-watch"
"${SUDO[@]}" install -m 0644 \
  "$INFRA_ROOT/systemd/platform-health-watch.service" \
  /etc/systemd/system/platform-health-watch.service
"${SUDO[@]}" install -m 0644 \
  "$INFRA_ROOT/systemd/platform-health-watch.timer" \
  /etc/systemd/system/platform-health-watch.timer
"${SUDO[@]}" systemctl daemon-reload
"${SUDO[@]}" systemctl enable --now platform-health-watch.timer
"${SUDO[@]}" systemctl status platform-health-watch.timer --no-pager
