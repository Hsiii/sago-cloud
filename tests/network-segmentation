#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

assert_contains() {
  local path=$1
  local text=$2

  if ! grep -Fq -- "$text" "$repo_root/$path"; then
    printf '%s does not contain required network declaration: %s\n' "$path" "$text" >&2
    exit 1
  fi
}

assert_absent() {
  local path=$1
  local text=$2

  if grep -Fq -- "$text" "$repo_root/$path"; then
    printf '%s contains forbidden network declaration: %s\n' "$path" "$text" >&2
    exit 1
  fi
}

frontend_files=(
  edge/compose.yaml
  services/bot-core/compose.yaml
  services/obi/compose.yaml
)

for compose_file in "${frontend_files[@]}"; do
  assert_contains "$compose_file" 'name: ${EDGE_NETWORK_NAME:-sago_cloud_edge}'
  assert_absent "$compose_file" 'sago_cloud_data'
done

assert_contains services/homepage/compose.yaml 'name: ${EDGE_NETWORK_NAME:-sago_cloud_edge}'
assert_absent services/homepage/compose.yaml 'sago_cloud_data'
assert_absent services/homepage/compose.yaml 'homepage-migrate'

assert_contains services/postgres/compose.yaml 'name: ${DATA_NETWORK_NAME:-sago_cloud_data}'
assert_absent services/postgres/compose.yaml 'sago_cloud_edge'
assert_absent scripts/lib/common.sh 'STACKS=(postgres '

assert_contains services/minisago-worker/compose.yaml 'name: ${EDGE_NETWORK_NAME:-sago_cloud_edge}'
assert_absent services/minisago-worker/compose.yaml 'sago_cloud_data'
assert_contains services/minisago-worker/compose.yaml 'MINISAGO_WORKER_CAPABILITIES: chat,dev'
assert_contains services/minisago-worker/compose.yaml '/srv/sago-cloud/secrets/minisago-worker.env'
assert_absent services/minisago-worker/compose.yaml '/srv/sago-cloud/secrets/minisago-worker-read.env'
assert_absent services/minisago-worker/compose.yaml '/srv/sago-cloud/secrets/minisago-worker-write.env'
assert_contains services/minisago-worker/compose.yaml 'minisago-github:/home/bun/.config/gh'
assert_contains services/minisago-worker/compose.yaml 'minisago-workspace:/workspace'
assert_absent services/minisago-worker/compose.yaml 'minisago-github-read:/home/bun/.config/gh-read'
assert_absent services/minisago-worker/compose.yaml 'minisago-github-write:/home/bun/.config/gh-write'

assert_contains scripts/lib/common.sh 'NETWORK_NAMES=("$EDGE_NETWORK_NAME" "$DATA_NETWORK_NAME")'
assert_contains scripts/lib/common.sh 'for network_name in "${NETWORK_NAMES[@]}"'

printf 'public services are isolated and Homepage uses its external Supabase backend\n'
