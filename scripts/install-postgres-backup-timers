#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

if [ "$(id -u)" -eq 0 ]; then
  SUDO=()
else
  SUDO=(sudo -n)
fi

units=(
  platform-postgres-backup.service
  platform-postgres-backup.timer
  platform-postgres-restore-test.service
  platform-postgres-restore-test.timer
)

for unit in "${units[@]}"; do
  "${SUDO[@]}" install -m 0644 "$OPERATIONS_ROOT/systemd/$unit" "/etc/systemd/system/$unit"
done

"${SUDO[@]}" install -d -o ubuntu -g ubuntu -m 0700 \
  "$BACKUPS_ROOT" \
  "$BACKUPS_ROOT/postgres"
"${SUDO[@]}" systemctl daemon-reload
"${SUDO[@]}" systemctl enable --now \
  platform-postgres-backup.timer \
  platform-postgres-restore-test.timer
"${SUDO[@]}" systemctl list-timers \
  platform-postgres-backup.timer \
  platform-postgres-restore-test.timer \
  --no-pager
