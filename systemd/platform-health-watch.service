[Unit]
Description=Restart unhealthy platform containers with a cooldown
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/
Environment=OPERATIONS_ROOT=/srv/platform/operations
Environment=PLATFORM_ROOT=/srv/platform
ExecStart=/usr/local/libexec/platform-health-watch/current/scripts/restart-unhealthy-services
TimeoutStartSec=10min
